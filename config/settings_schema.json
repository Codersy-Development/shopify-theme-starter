[
  {
    "name": "theme_info",
    "theme_name": "Vitality",
    "theme_version": "1.0.0",
    "theme_author": "Codersy",
    "theme_documentation_url": "https://codersy.com",
    "theme_support_url": "https://codersy.com"
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "Page width",
        "options": [
          { "value": "1200", "label": "Narrow (1200px)" },
          { "value": "1400", "label": "Default (1400px)" },
          { "value": "1600", "label": "Wide (1600px)" },
          { "value": "full", "label": "Full width" }
        ],
        "default": "1400"
      },
      {
        "type": "range",
        "id": "padding_mobile",
        "label": "Horizontal padding (mobile)",
        "min": 12,
        "max": 40,
        "step": 4,
        "unit": "px",
        "default": 16
      },
      {
        "type": "range",
        "id": "padding_desktop",
        "label": "Horizontal padding (desktop)",
        "min": 20,
        "max": 80,
        "step": 4,
        "unit": "px",
        "default": 40
      }
    ]
  },
  {
    "name": "Logo & Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Logo max width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32x32px .png recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary",
        "default": "#2D6A4F",
        "info": "Main brand color — buttons, links, accents"
      },
      {
        "type": "color",
        "id": "color_primary_light",
        "label": "Primary light",
        "default": "#52B788",
        "info": "Hover states, badges, highlights"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary",
        "default": "#B7791F",
        "info": "Earth/gold accent — trust signals, icons"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#1B4332",
        "info": "Deep accent for headers, emphasis"
      },
      {
        "type": "header",
        "content": "Surface colors"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_background_alt",
        "label": "Alternate background",
        "default": "#F0FFF4",
        "info": "Light tinted sections"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#1A202C"
      },
      {
        "type": "color",
        "id": "color_text_light",
        "label": "Text light",
        "default": "#718096"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#E2E8F0"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "playfair_display_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      }
    ]
  },
  {
    "name": "Trust badges",
    "settings": [
      {
        "type": "header",
        "content": "Trust badge bar"
      },
      {
        "type": "checkbox",
        "id": "trust_bar_enabled",
        "label": "Show trust badge bar below header",
        "default": true
      },
      {
        "type": "text",
        "id": "trust_badge_1",
        "label": "Badge 1 text",
        "default": "GMP Certified"
      },
      {
        "type": "text",
        "id": "trust_badge_2",
        "label": "Badge 2 text",
        "default": "Third-Party Tested"
      },
      {
        "type": "text",
        "id": "trust_badge_3",
        "label": "Badge 3 text",
        "default": "Made in USA"
      },
      {
        "type": "text",
        "id": "trust_badge_4",
        "label": "Badge 4 text",
        "default": "Free Shipping $50+"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer",
        "info": "Choose how the cart is displayed."
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "label": "Enable predictive search",
        "default": true
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
        "info": "https://facebook.com/your-page"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/your-handle"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok",
        "info": "https://tiktok.com/@your-handle"
      },
      {
        "type": "text",
        "id": "social_x_link",
        "label": "X (Twitter)",
        "info": "https://x.com/your-handle"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "info": "https://youtube.com/your-channel"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest",
        "info": "https://pinterest.com/your-page"
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "text",
        "id": "seo_google_site_verification",
        "label": "Google site verification",
        "info": "Content value from Google Search Console meta tag"
      }
    ]
  }
]
