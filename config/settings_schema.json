[
  {
    "name": "theme_info",
    "theme_name": "Shopify Theme Starter",
    "theme_version": "1.0.0",
    "theme_author": "Codersy",
    "theme_documentation_url": "https://codersy.com",
    "theme_support_url": "https://codersy.com"
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "Page width",
        "options": [
          { "value": "1200", "label": "Narrow (1200px)" },
          { "value": "1400", "label": "Default (1400px)" },
          { "value": "1600", "label": "Wide (1600px)" },
          { "value": "full", "label": "Full width" }
        ],
        "default": "1400"
      },
      {
        "type": "range",
        "id": "padding_mobile",
        "label": "Horizontal padding (mobile)",
        "min": 12,
        "max": 40,
        "step": 4,
        "unit": "px",
        "default": 16
      },
      {
        "type": "range",
        "id": "padding_desktop",
        "label": "Horizontal padding (desktop)",
        "min": 20,
        "max": 80,
        "step": 4,
        "unit": "px",
        "default": 40
      }
    ]
  },
  {
    "name": "Logo & Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Logo max width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32x32px .png recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#111827"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary color",
        "default": "#2563eb"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer",
        "info": "Choose how the cart is displayed. Drawer slides in from the right, page navigates to /cart."
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "label": "Enable predictive search",
        "default": true,
        "info": "Show search suggestions as you type."
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
        "info": "https://facebook.com/your-page"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/your-handle"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok",
        "info": "https://tiktok.com/@your-handle"
      },
      {
        "type": "text",
        "id": "social_x_link",
        "label": "X (Twitter)",
        "info": "https://x.com/your-handle"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "info": "https://youtube.com/your-channel"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest",
        "info": "https://pinterest.com/your-page"
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "text",
        "id": "seo_google_site_verification",
        "label": "Google site verification",
        "info": "Content value from Google Search Console meta tag"
      }
    ]
  }
]
