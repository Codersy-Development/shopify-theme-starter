<predictive-search class="relative">
  <button
    type="button"
    class="text-gray-700 hover:text-gray-900 cursor-pointer"
    aria-label="Search"
    data-open-search
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>

  <div class="predictive-search-results fixed inset-0 z-50 bg-white flex flex-col md:absolute md:inset-auto md:right-0 md:top-full md:mt-2 md:w-96 md:max-h-[80vh] md:rounded-xl md:shadow-2xl md:border md:border-gray-200 overflow-hidden" role="listbox" aria-label="Search suggestions">
    <!-- Mobile header -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 md:hidden">
      <span class="text-lg font-semibold">Search</span>
      <button type="button" data-close-search class="text-gray-400 hover:text-gray-600 cursor-pointer p-1" aria-label="Close search">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form action="/search" method="get" role="search" class="border-b border-gray-100">
      <div class="flex items-center gap-2 px-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-4 md:w-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <label for="predictive-search-input" class="visually-hidden">Search</label>
        <input
          type="search"
          id="predictive-search-input"
          name="q"
          placeholder="Search..."
          autocomplete="off"
          data-search-input
          class="w-full py-4 md:py-3 text-base md:text-sm bg-transparent border-0 focus:outline-none focus:ring-0 appearance-none"
        >
        <!-- Desktop close -->
        <button type="button" data-close-search class="hidden md:block text-gray-400 hover:text-gray-600 cursor-pointer shrink-0" aria-label="Close search">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </form>

    <div data-search-results class="flex-1 overflow-y-auto md:max-h-96">
      <div class="px-4 py-8 text-center text-sm text-gray-400">
        Start typing to search...
      </div>
    </div>
  </div>
</predictive-search>
