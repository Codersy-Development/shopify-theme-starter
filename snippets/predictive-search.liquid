<predictive-search class="hidden md:block relative">
  <button
    type="button"
    class="text-gray-700 hover:text-gray-900 cursor-pointer"
    aria-label="Search"
    data-open-search
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>

  <div class="predictive-search-results absolute right-0 top-full mt-2 w-96 bg-white rounded-xl shadow-2xl border border-gray-200 overflow-hidden z-50" role="listbox" aria-label="Search suggestions">
    <form action="/search" method="get" role="search" class="border-b border-gray-100">
      <div class="flex items-center px-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <label for="predictive-search-input" class="visually-hidden">Search</label>
        <input
          type="search"
          id="predictive-search-input"
          name="q"
          placeholder="Search..."
          autocomplete="off"
          data-search-input
          class="w-full px-3 py-3 text-sm border-0 focus:outline-none focus:ring-0"
        >
        <button type="button" data-close-search class="text-gray-400 hover:text-gray-600 cursor-pointer" aria-label="Close search">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </form>

    <div data-search-results class="max-h-96 overflow-y-auto">
      <div class="px-4 py-8 text-center text-sm text-gray-400">
        Start typing to search...
      </div>
    </div>
  </div>
</predictive-search>
