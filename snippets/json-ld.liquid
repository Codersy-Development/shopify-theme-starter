{%- comment -%} Organization {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
    {%- if settings.logo != blank -%}
      ,"logo": {{ settings.logo | image_url: width: 600 | prepend: 'https:' | json }}
    {%- endif -%}
    {%- if shop.description != blank -%}
      ,"description": {{ shop.description | json }}
    {%- endif -%}
    {%- capture social_links_json -%}
      {%- if settings.social_facebook_link != blank -%},{{ settings.social_facebook_link | json }}{%- endif -%}
      {%- if settings.social_instagram_link != blank -%},{{ settings.social_instagram_link | json }}{%- endif -%}
      {%- if settings.social_tiktok_link != blank -%},{{ settings.social_tiktok_link | json }}{%- endif -%}
      {%- if settings.social_x_link != blank -%},{{ settings.social_x_link | json }}{%- endif -%}
      {%- if settings.social_youtube_link != blank -%},{{ settings.social_youtube_link | json }}{%- endif -%}
      {%- if settings.social_pinterest_link != blank -%},{{ settings.social_pinterest_link | json }}{%- endif -%}
    {%- endcapture -%}
    {%- if social_links_json != blank -%}
      ,"sameAs": [{{ social_links_json | remove_first: ',' }}]
    {%- endif -%}
  }
</script>

{%- comment -%} WebSite + SearchAction {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "{{ shop.url }}/search?q={% raw %}{search_term_string}{% endraw %}"
      },
      "query-input": "required name=search_term_string"
    }
  }
</script>

{%- comment -%} BreadcrumbList {%- endcomment -%}
{%- capture crumb_items_json -%}
  {%- case request.page_type -%}
    {%- when 'product' -%}
      {%- comment -%} Mirrors snippets/breadcrumbs.liquid: metafield first, then first collection {%- endcomment -%}
      {%- assign crumb_pos = 2 -%}
      {%- assign product_category = product.metafields.breadcrumb.category.value | default: product.collections.first -%}
      {%- if product_category -%}
        ,{ "@type": "ListItem", "position": {{ crumb_pos }}, "name": {{ product_category.title | json }}, "item": {{ shop.url | append: product_category.url | json }} }
        {%- assign crumb_pos = crumb_pos | plus: 1 -%}
        {%- assign product_subcategory = product.metafields.breadcrumb.subcategory.value -%}
        {%- if product_subcategory -%}
          ,{ "@type": "ListItem", "position": {{ crumb_pos }}, "name": {{ product_subcategory.title | json }}, "item": {{ shop.url | append: product_subcategory.url | json }} }
          {%- assign crumb_pos = crumb_pos | plus: 1 -%}
        {%- endif -%}
      {%- endif -%}
      ,{ "@type": "ListItem", "position": {{ crumb_pos }}, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }

    {%- when 'collection' -%}
      {%- assign crumb_pos = 2 -%}
      {%- assign collection_category = collection.metafields.breadcrumb.category.value -%}
      {%- if collection_category -%}
        ,{ "@type": "ListItem", "position": {{ crumb_pos }}, "name": {{ collection_category.title | json }}, "item": {{ shop.url | append: collection_category.url | json }} }
        {%- assign crumb_pos = crumb_pos | plus: 1 -%}
      {%- endif -%}
      ,{ "@type": "ListItem", "position": {{ crumb_pos }}, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }} }

    {%- when 'article' -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ article.blog.title | json }}, "item": {{ shop.url | append: article.blog.url | json }} }
      ,{ "@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }} }

    {%- when 'page' -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ page.title | json }}, "item": {{ shop.url | append: page.url | json }} }
  {%- endcase -%}
{%- endcapture -%}

{%- if crumb_items_json != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": {{ shop.name | json }}, "item": {{ shop.url | json }} }
        {{ crumb_items_json }}
      ]
    }
  </script>
{%- endif -%}

{%- comment -%} Product {%- endcomment -%}
{%- comment -%}
  Shopify's structured_data filter emits Google's current Product schema
  (ProductGroup with per-variant offers for multi-variant products) and is
  kept up to date by Shopify. Review apps inject their own rating schema.
{%- endcomment -%}
{%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>

  {%- if product.metafields.reviews.rating.value != blank -%}
    {%- assign rating_value = product.metafields.reviews.rating.value -%}
    {%- assign rating_count = product.metafields.reviews.rating_count.value -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Product",
        "@id": {{ product.url | append: '#product' | json }},
        "name": {{ product.title | json }},
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": {{ rating_value.rating | json }},
          "bestRating": {{ rating_value.scale_max | json }},
          "worstRating": {{ rating_value.scale_min | json }},
          "ratingCount": {{ rating_count | json }}
        }
      }
    </script>
  {%- endif -%}
{%- endif -%}

{%- comment -%} Article — native filter, kept current by Shopify {%- endcomment -%}
{%- if request.page_type == 'article' -%}
  <script type="application/ld+json">
    {{ article | structured_data }}
  </script>
{%- endif -%}

{%- comment -%} CollectionPage {%- endcomment -%}
{%- if request.page_type == 'collection' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": {{ collection.title | json }},
      "url": {{ shop.url | append: collection.url | json }}
      {%- if collection.description != blank -%}
        ,"description": {{ collection.description | strip_html | json }}
      {%- endif -%}
      {%- if collection.image -%}
        ,"image": {{ collection.image | image_url: width: 1200 | prepend: 'https:' | json }}
      {%- endif -%}
      ,"numberOfItems": {{ collection.products_count }}
      ,"mainEntity": {
        "@type": "ItemList",
        "numberOfItems": {{ collection.products_count }},
        "itemListElement": [
          {%- for product in collection.products limit: 30 -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": {{ shop.url | append: product.url | json }},
              "name": {{ product.title | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      }
    }
  </script>
{%- endif -%}
