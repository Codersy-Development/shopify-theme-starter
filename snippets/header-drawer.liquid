<header-drawer class="contents">
  <button
    type="button"
    class="md:hidden text-gray-700 hover:text-gray-900 cursor-pointer"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu-panel"
    data-open
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <div data-overlay class="fixed inset-0 z-40"></div>

  <div
    id="mobile-menu-panel"
    data-panel
    role="dialog"
    aria-modal="true"
    aria-label="Mobile menu"
    class="fixed top-0 left-0 w-full max-w-xs h-full bg-white shadow-xl flex flex-col z-50"
  >
    <div class="flex items-center justify-between px-4 py-4 border-b border-gray-200">
      <span class="text-lg font-semibold">Menu</span>
      <button data-close type="button" class="text-gray-400 hover:text-gray-600 cursor-pointer" aria-label="Close menu">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-4 py-4" aria-label="Mobile navigation">
      <accordion-group data-allow-multiple>
        {% for link in linklists[menu].links %}
          {% if link.links.size > 0 %}
            <div class="accordion-item border-b border-gray-100" data-accordion>
              <div class="flex items-center">
                <a
                  href="{{ link.url }}"
                  class="flex-1 py-3 text-gray-900 no-underline"
                  {% if link.active %}
                    aria-current="page"
                  {% endif %}
                >
                  {{ link.title }}
                </a>
                <button
                  type="button"
                  class="p-2 text-gray-500 hover:text-gray-900 cursor-pointer bg-transparent border-0"
                  aria-expanded="false"
                  aria-label="Expand {{ link.title }}"
                  data-accordion-trigger
                >
                  <svg
                    class="w-4 h-4 transition-transform accordion-icon-closed"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                  <svg
                    class="w-4 h-4 transition-transform accordion-icon-open"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
                  </svg>
                </button>
              </div>

              <div class="accordion-content">
                <div>
                  <ul class="list-none p-0 m-0 pb-3">
                    {% for child in link.links %}
                      <li>
                        <a
                          href="{{ child.url }}"
                          class="block py-2 pl-4 text-sm text-gray-600 hover:text-gray-900 no-underline"
                        >
                          {{ child.title }}
                        </a>

                        {% if child.links.size > 0 %}
                          <ul class="list-none p-0 m-0">
                            {% for grandchild in child.links %}
                              <li>
                                <a
                                  href="{{ grandchild.url }}"
                                  class="block py-1.5 pl-8 text-sm text-gray-500 hover:text-gray-900 no-underline"
                                >
                                  {{ grandchild.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
            </div>
          {% else %}
            <a
              href="{{ link.url }}"
              class="block py-3 text-gray-900 border-b border-gray-100 no-underline"
              {% if link.active %}
                aria-current="page"
              {% endif %}
            >
              {{ link.title }}
            </a>
          {% endif %}
        {% endfor %}
      </accordion-group>
    </nav>
  </div>
</header-drawer>
