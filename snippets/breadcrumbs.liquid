{%- comment -%}
  Breadcrumb navigation for the current page (up to 4 levels).

  Levels:
    - Level 1 (Home)
    - Level 2 (Category) - Optional, requires collection reference metafield
    - Level 3 (Subcategory) - Optional, requires collection reference metafield
    - Level 4 (Product / Current page)

  Metafield Setup:
    For products: Add metafields 'breadcrumb.category' and 'breadcrumb.subcategory'
    For collections: Add metafield 'breadcrumb.category'
    These should be collection reference metafields pointing to parent collections.

  Structured data (BreadcrumbList JSON-LD) is emitted by snippets/json-ld.liquid.
{%- endcomment -%}

{%- liquid
  case template.name
    when 'product'
      assign template_object = product
      assign category_object = product.metafields.breadcrumb.category.value
      assign subcategory_object = product.metafields.breadcrumb.subcategory.value
    when 'collection'
      assign template_object = collection
      assign category_object = collection.metafields.breadcrumb.category.value
    when 'article'
      assign template_object = article
      assign category_object = article.blog
    when 'blog'
      assign template_object = blog
    when 'page'
      assign template_object = page
  endcase
-%}

{% if template_object %}
  <nav aria-label="Breadcrumb" class="text-sm py-6 md:py-7">
    <ol class="flex items-center overflow-x-auto list-none p-0 m-0">
      <li>
        <a
          href="{{ routes.root_url }}"
          class="text-gray-900 hover:text-gray-600 no-underline transition-colors"
        >
          {{- 'breadcrumb.home' | t -}}
        </a>
      </li>
      {% if category_object %}
        <li class="mx-2" aria-hidden="true">
          <svg
            width="16"
            height="16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="text-gray-400"
          >
            <circle cx="8" cy="8" r="2" fill="currentColor"/>
          </svg>
        </li>
        <li>
          <a
            href="{{ category_object.url }}"
            class="text-gray-900 hover:text-gray-600 no-underline transition-colors whitespace-nowrap"
          >
            {{- category_object.title -}}
          </a>
        </li>
      {% endif %}
      {% if subcategory_object %}
        <li class="mx-2" aria-hidden="true">
          <svg
            width="16"
            height="16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="text-gray-400"
          >
            <circle cx="8" cy="8" r="2" fill="currentColor"/>
          </svg>
        </li>
        <li>
          <a
            href="{{ subcategory_object.url }}"
            class="text-gray-900 hover:text-gray-600 no-underline transition-colors whitespace-nowrap"
          >
            {{- subcategory_object.title -}}
          </a>
        </li>
      {% endif %}
      <li class="mx-2" aria-hidden="true">
        <svg
          width="16"
          height="16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="text-gray-400"
        >
          <circle cx="8" cy="8" r="2" fill="currentColor"/>
        </svg>
      </li>
      <li>
        <span class="text-gray-500 font-medium whitespace-nowrap" aria-current="page">
          {{- template_object.title -}}
        </span>
      </li>
    </ol>
  </nav>
{% endif %}
