<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }}</title>

    {{ 'application.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center bg-gray-50">
    <main class="w-full max-w-md mx-auto px-4 py-12 text-center">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{{ shop.name }}</h1>
      <p class="text-gray-500 mb-8">We're getting things ready. Come back soon!</p>

      {{ content_for_layout }}

      {% if shop.password_message != blank %}
        <div class="text-sm text-gray-500 mt-8">
          {{ shop.password_message }}
        </div>
      {% endif %}
    </main>

    <footer class="py-6 text-center text-sm text-gray-400">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
    </footer>
  </body>
</html>
