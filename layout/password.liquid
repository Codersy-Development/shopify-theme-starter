<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }}</title>

    {{ 'application.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}

    <style>
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-primary-light: {{ settings.color_primary_light }};
        --color-accent: {{ settings.color_accent }};
        --color-background-alt: {{ settings.color_background_alt }};
        --color-text: {{ settings.color_text }};
        --color-text-light: {{ settings.color_text_light }};
        --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
        --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center bg-[var(--color-background-alt)]" style="font-family: var(--font-body);">
    <main class="w-full max-w-md mx-auto px-4 py-12 text-center">
      <h1 class="text-3xl font-bold mb-2" style="font-family: var(--font-heading); color: var(--color-accent);">{{ shop.name }}</h1>
      <p class="text-[var(--color-text-light)] mb-8">We're getting things ready. Come back soon!</p>

      {{ content_for_layout }}

      {% if shop.password_message != blank %}
        <div class="text-sm text-[var(--color-text-light)] mt-8">
          {{ shop.password_message }}
        </div>
      {% endif %}
    </main>

    <footer class="py-6 text-center text-sm text-[var(--color-text-light)]">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
    </footer>
  </body>
</html>
