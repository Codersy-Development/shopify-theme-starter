{%- if section.settings.text != blank -%}
  <div class="bg-gray-900 text-white text-center text-sm py-2 px-4">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="text-white hover:text-gray-200 no-underline">
        {{ section.settings.text }}
      </a>
    {%- else -%}
      <p class="m-0">{{ section.settings.text }}</p>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
