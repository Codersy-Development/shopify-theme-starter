<cart-drawer class="contents">
  <div data-overlay class="fixed inset-0 z-40"></div>

  <div
    data-panel
    role="dialog"
    aria-modal="true"
    aria-label="Shopping cart"
    class="fixed top-0 right-0 h-full w-full sm:max-w-md bg-[var(--color-background)] shadow-xl flex flex-col z-50"
  >
    <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)]">
      <h2 class="text-lg font-semibold" style="font-family: var(--font-heading);">Cart</h2>
      <button data-close type="button" class="text-[var(--color-text-light)] hover:text-[var(--color-text)] cursor-pointer" aria-label="Close cart">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div data-cart-drawer-content class="flex-1 overflow-y-auto">
      {% if cart.item_count > 0 %}
        <ul class="divide-y divide-[var(--color-border)] px-6" role="list">
          {% for item in cart.items %}
            <li class="flex gap-4 py-4">
              <div class="w-16 h-16 bg-[var(--color-background-alt)] rounded-lg overflow-hidden shrink-0">
                {% render 'image',
                  image: item.image,
                  max_width: 200,
                  sizes: '64px',
                  alt: item.product.title,
                  class: 'w-full h-full object-cover'
                %}
              </div>

              <div class="flex-1 min-w-0">
                <a href="{{ item.url }}" class="text-sm font-medium text-[var(--color-text)] no-underline">
                  {{ item.product.title }}
                </a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="text-xs text-[var(--color-text-light)] mt-0.5">{{ item.variant.title }}</p>
                {% endif %}
                <p class="text-sm text-[var(--color-text-light)] mt-0.5">
                  <span class="visually-hidden">Price:</span> {{ item.price | money }}
                </p>

                <div class="flex items-center gap-3 mt-2">
                  <div class="flex items-center border border-[var(--color-border)] rounded-lg">
                    <button
                      type="button"
                      class="w-8 h-8 flex items-center justify-center text-[var(--color-text-light)] hover:text-[var(--color-text)] cursor-pointer"
                      aria-label="Decrease quantity for {{ item.product.title }}"
                      data-change-qty
                      data-line="{{ forloop.index }}"
                      data-qty="{{ item.quantity | minus: 1 }}"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" d="M5 12h14"/></svg>
                    </button>
                    <span class="w-8 text-center text-sm" aria-label="Quantity: {{ item.quantity }}">{{ item.quantity }}</span>
                    <button
                      type="button"
                      class="w-8 h-8 flex items-center justify-center text-[var(--color-text-light)] hover:text-[var(--color-text)] cursor-pointer"
                      aria-label="Increase quantity for {{ item.product.title }}"
                      data-change-qty
                      data-line="{{ forloop.index }}"
                      data-qty="{{ item.quantity | plus: 1 }}"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
                    </button>
                  </div>

                  <button
                    type="button"
                    class="text-xs text-[var(--color-text-light)] hover:text-red-600 cursor-pointer transition-colors"
                    aria-label="Remove {{ item.product.title }} from cart"
                    data-change-qty
                    data-line="{{ forloop.index }}"
                    data-qty="0"
                  >
                    Remove
                  </button>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <div class="flex flex-col items-center justify-center h-full text-center px-6">
          <p class="text-[var(--color-text-light)] mb-4">Your cart is empty.</p>
          <a href="/collections/all" class="text-sm font-medium text-[var(--color-primary)] underline" data-close>
            Continue shopping
          </a>
        </div>
      {% endif %}
    </div>

    {% if cart.item_count > 0 %}
      <div data-cart-drawer-footer class="border-t border-[var(--color-border)] px-6 py-4">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-semibold">Subtotal</span>
          <span class="text-sm font-semibold">{{ cart.total_price | money }}</span>
        </div>

        <a
          href="/checkout"
          class="block w-full bg-[var(--color-primary)] text-white text-center font-semibold px-8 py-3 rounded-lg hover:bg-[var(--color-primary-light)] transition-colors no-underline"
        >
          Checkout
        </a>

        <a
          href="/cart"
          class="block w-full text-center text-sm text-[var(--color-text-light)] mt-2 hover:text-[var(--color-text)] no-underline"
        >
          View cart
        </a>
      </div>
    {% endif %}
  </div>
</cart-drawer>

{% schema %}
{
  "name": "Cart Drawer",
  "tag": "section"
}
{% endschema %}
