<cart-drawer class="contents" aria-hidden="true">
  <!-- Overlay -->
  <div data-overlay class="fixed inset-0 bg-black/0 pointer-events-none transition-[background-color] duration-300 z-40"></div>

  <!-- Drawer -->
  <div data-panel class="fixed top-0 right-0 w-full max-w-md h-full bg-white shadow-xl flex flex-col translate-x-full transition-transform duration-300 ease-out z-50">
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold">Cart</h2>
      <button data-close type="button" class="text-gray-400 hover:text-gray-600 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Content -->
    <div data-cart-drawer-content class="flex-1 overflow-y-auto">
      {% if cart.item_count > 0 %}
        <div class="divide-y divide-gray-200 px-6">
          {% for item in cart.items %}
            <div class="flex items-center gap-4 py-4">
              <div class="w-16 h-16 bg-gray-100 rounded-lg overflow-hidden shrink-0">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.image.alt | escape }}"
                    class="w-full h-full object-cover"
                    width="160"
                    height="160"
                  >
                {% endif %}
              </div>

              <div class="flex-1 min-w-0">
                <a href="{{ item.url }}" class="text-sm font-medium text-gray-900 no-underline">
                  {{ item.product.title }}
                </a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="text-xs text-gray-500 mt-0.5">{{ item.variant.title }}</p>
                {% endif %}
                <p class="text-sm text-gray-600 mt-0.5">{{ item.price | money }} &times; {{ item.quantity }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="flex flex-col items-center justify-center h-full text-center px-6">
          <p class="text-gray-500 mb-4">Your cart is empty.</p>
          <a href="/collections/all" class="text-sm font-medium text-gray-900 underline" data-close>
            Continue shopping
          </a>
        </div>
      {% endif %}
    </div>

    <!-- Footer -->
    {% if cart.item_count > 0 %}
      <div class="border-t border-gray-200 px-6 py-4">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-semibold">Subtotal</span>
          <span class="text-sm font-semibold">{{ cart.total_price | money }}</span>
        </div>

        <a
          href="/checkout"
          class="block w-full bg-gray-900 text-white text-center font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors no-underline"
        >
          Checkout
        </a>

        <a
          href="/cart"
          class="block w-full text-center text-sm text-gray-600 mt-2 hover:text-gray-900 no-underline"
        >
          View cart
        </a>
      </div>
    {% endif %}
  </div>
</cart-drawer>

{% schema %}
{
  "name": "Cart Drawer",
  "tag": "section"
}
{% endschema %}
