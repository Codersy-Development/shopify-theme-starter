{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
-%}

<section class="relative overflow-hidden {% if has_image %}text-white{% else %}bg-[var(--color-accent)] text-white{% endif %}">
  {%- if has_image -%}
    <div class="absolute inset-0">
      {% render 'image',
        image: section.settings.image,
        max_width: 2000,
        widths: '600, 1000, 1400, 1800, 2000',
        sizes: '100vw',
        alt: section.settings.heading,
        loading: 'eager',
        fetchpriority: 'high',
        class: 'w-full h-full object-cover'
      %}
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}), rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 | times: 0.6 }}));"></div>
    </div>
  {%- endif -%}

  <div class="page-width relative py-20 md:py-32 lg:py-40 {% if section.settings.text_align == 'center' %}text-center{% else %}max-w-2xl{% endif %}">
    {%- if section.settings.subtitle != blank -%}
      <p class="text-sm md:text-base uppercase tracking-widest mb-4 {% if has_image %}text-white/80{% else %}text-white/70{% endif %}" style="font-family: var(--font-body);">
        {{ section.settings.subtitle }}
      </p>
    {%- endif -%}

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 leading-tight" style="font-family: var(--font-heading);">
      {{ section.settings.heading }}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p class="text-lg sm:text-xl {% if has_image %}text-white/90{% else %}text-white/80{% endif %} max-w-2xl {% if section.settings.text_align == 'center' %}mx-auto{% endif %} mb-8">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="flex gap-4 {% if section.settings.text_align == 'center' %}justify-center{% endif %} flex-wrap">
      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="inline-block bg-[var(--color-primary)] text-white font-semibold px-8 py-3.5 rounded-lg hover:opacity-90 transition-opacity no-underline"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_label_2 != blank -%}
        <a
          href="{{ section.settings.button_link_2 }}"
          class="inline-block border-2 border-white text-white font-semibold px-8 py-3.5 rounded-lg hover:bg-white hover:text-[var(--color-accent)] transition-colors no-underline"
        >
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium supplements"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fuel your body with nature's best"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Description",
      "default": "Science-backed supplements crafted from the purest ingredients for your health and wellness journey."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
