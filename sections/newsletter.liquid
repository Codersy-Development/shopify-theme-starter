<section class="py-12 md:py-16 bg-[var(--color-primary)] text-white">
  <div class="page-width max-w-2xl text-center">
    {% if section.settings.subtitle != blank %}
      <p class="text-sm uppercase tracking-widest text-white/70 mb-3">{{ section.settings.subtitle }}</p>
    {% endif %}

    <h2 class="text-2xl sm:text-3xl font-bold mb-4" style="font-family: var(--font-heading);">
      {{ section.settings.heading }}
    </h2>

    {% if section.settings.description != blank %}
      <p class="text-white/80 mb-8">{{ section.settings.description }}</p>
    {% endif %}

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
        <label for="newsletter-email-section" class="visually-hidden">Email address</label>
        <input
          type="email"
          id="newsletter-email-section"
          name="contact[email]"
          placeholder="Enter your email"
          required
          aria-required="true"
          autocomplete="email"
          class="flex-1 bg-white/15 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-white/50 focus:border-transparent"
        >
        <button
          type="submit"
          class="bg-white text-[var(--color-primary)] font-semibold px-8 py-3 rounded-lg hover:bg-white/90 transition-colors cursor-pointer whitespace-nowrap"
        >
          {{ section.settings.button_label }}
        </button>
      </div>
    {% endform %}

    {% if section.settings.disclaimer != blank %}
      <p class="text-xs text-white/50 mt-4">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Join the wellness community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 15% Off Your First Order"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Subscribe for wellness tips, new product launches, and exclusive subscriber-only discounts."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "No spam, unsubscribe anytime. We respect your privacy."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
