<section>
  {% form 'storefront_password' %}
    <div class="space-y-4">
      {% if form.errors %}
        <p class="text-sm text-red-600">{{ form.errors.messages['form'] }}</p>
      {% endif %}

      <div>
        <label for="password" class="sr-only">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Enter store password"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-center focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
        >
      </div>

      <button
        type="submit"
        class="w-full bg-gray-900 text-white font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer"
      >
        Enter
      </button>
    </div>
  {% endform %}
</section>

{% schema %}
{
  "name": "Password",
  "tag": "section"
}
{% endschema %}
