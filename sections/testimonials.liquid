<section class="py-12 md:py-16 bg-[var(--color-background-alt)]">
  <div class="page-width">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-4" style="font-family: var(--font-heading);">
      {{ section.settings.heading }}
    </h2>
    {% if section.settings.subheading != blank %}
      <p class="text-center text-[var(--color-text-light)] max-w-2xl mx-auto mb-10">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for block in section.blocks %}
        <div class="bg-[var(--color-background)] rounded-xl p-6 border border-[var(--color-border)]" {{ block.shopify_attributes }}>
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% for i in (1..5) %}
              <svg class="w-5 h-5 {% if i <= block.settings.rating %}text-yellow-400{% else %}text-gray-200{% endif %}" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {% endfor %}
          </div>

          {% if block.settings.title != blank %}
            <h3 class="font-bold mb-2">{{ block.settings.title }}</h3>
          {% endif %}

          <p class="text-sm text-[var(--color-text-light)] mb-4 leading-relaxed">{{ block.settings.text }}</p>

          <div class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)]">
            {% if block.settings.avatar != blank %}
              <div class="w-10 h-10 rounded-full overflow-hidden shrink-0">
                {% render 'image',
                  image: block.settings.avatar,
                  max_width: 80,
                  sizes: '40px',
                  alt: block.settings.author,
                  class: 'w-full h-full object-cover'
                %}
              </div>
            {% else %}
              <div class="w-10 h-10 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center shrink-0">
                <span class="text-sm font-semibold text-[var(--color-primary)]">{{ block.settings.author | truncate: 1, '' | upcase }}</span>
              </div>
            {% endif %}
            <div>
              <p class="text-sm font-semibold">{{ block.settings.author }}</p>
              {% if block.settings.verified %}
                <p class="text-xs text-[var(--color-primary)] flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Verified Buyer
                </p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real people on their wellness journey."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Life changing supplement!"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "I've been taking this for 3 months and the difference in my energy levels is incredible. Highly recommend!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author photo"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "title": "Life changing supplement!", "text": "I've been taking this for 3 months and the difference in my energy levels is incredible. Highly recommend!", "author": "Sarah M.", "rating": 5, "verified": true } },
        { "type": "testimonial", "settings": { "title": "Best quality I've found", "text": "After trying many brands, this is the only one that uses truly clean ingredients. My digestion has improved so much.", "author": "James K.", "rating": 5, "verified": true } },
        { "type": "testimonial", "settings": { "title": "Worth every penny", "text": "The subscription saves me money and I never have to worry about running out. The quality is consistently excellent.", "author": "Michelle R.", "rating": 5, "verified": true } }
      ]
    }
  ]
}
{% endschema %}
