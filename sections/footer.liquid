<footer class="bg-gray-50 border-t border-gray-200 mt-auto" role="contentinfo">
  <div class="page-width py-12">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <a href="/" class="inline-block mb-4 no-underline" title="{{ shop.name }}">
          {% if settings.logo != blank %}
            <img
              src="{{ settings.logo | image_url: width: 100 }}"
              alt="{{ shop.name }}"
              style="max-width: 100px"
              width="100"
              height="{{ 100 | divided_by: settings.logo.aspect_ratio | round }}"
            >
          {% else %}
            <span class="text-sm font-semibold text-gray-900 uppercase tracking-wider">{{ shop.name }}</span>
          {% endif %}
        </a>
        {% if section.settings.about_text != blank %}
          <p class="text-sm text-gray-500">{{ section.settings.about_text }}</p>
        {% endif %}
        <div class="mt-4">
          {% render 'social-icons' %}
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Quick links</h3>
        <nav class="space-y-2" aria-label="Footer navigation">
          {% for link in linklists[section.settings.menu].links %}
            <a href="{{ link.url }}" class="block text-sm text-gray-500 hover:text-gray-700 no-underline">
              {{ link.title }}
            </a>
          {% endfor %}
        </nav>
      </div>

      {% if section.settings.show_newsletter %}
        <div>
          <h3 id="newsletter-heading" class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Stay in touch</h3>
          <p class="text-sm text-gray-500 mb-3">Subscribe for updates and promotions.</p>
          {% form 'customer' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="flex gap-2">
              <label for="newsletter-email" class="visually-hidden">Email address</label>
              <input
                type="email"
                id="newsletter-email"
                name="contact[email]"
                placeholder="Your email"
                required
                aria-required="true"
                autocomplete="email"
                class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              >
              <button
                type="submit"
                class="bg-gray-900 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer"
              >
                Subscribe
              </button>
            </div>
          {% endform %}
        </div>
      {% endif %}
    </div>

    <div class="border-t border-gray-200 pt-8 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-sm text-gray-400">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <p class="text-sm text-gray-400">
        Shopify theme by <a href="https://www.codersy.com" class="text-gray-500 hover:text-gray-700 no-underline" title="Codersy - Shopify Development">Codersy</a>
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "about_text",
      "label": "About text"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    }
  ]
}
{% endschema %}
