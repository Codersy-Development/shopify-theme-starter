<footer class="bg-gray-50 border-t border-gray-200 mt-auto" role="contentinfo">
  <div class="page-width py-12">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <a
          href="{{ routes.root_url }}"
          class="inline-block mb-4 no-underline"
          title="{{ shop.name }}"
        >
          {% if settings.logo != blank %}
            {% render 'image',
              image: settings.logo,
              max_width: 100,
              sizes: '100px',
              alt: shop.name,
              loading: 'eager',
              style: 'max-width: 100px'
            %}
          {% else %}
            <span class="text-sm font-semibold text-gray-900 uppercase tracking-wider">
              {{- shop.name -}}
            </span>
          {% endif %}
        </a>
        {% if section.settings.about_text != blank %}
          <p class="text-sm text-gray-500">{{ section.settings.about_text }}</p>
        {% endif %}
        <div class="mt-4">
          {% render 'social-icons' %}
        </div>
      </div>

      <div>
        <p class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">
          {{ 'footer.quick_links' | t }}
        </p>
        <nav class="space-y-2" aria-label="{{ 'footer.navigation_label' | t }}">
          {% for link in linklists[section.settings.menu].links %}
            <a
              href="{{ link.url }}"
              class="block text-sm text-gray-500 hover:text-gray-700 no-underline"
            >
              {{ link.title }}
            </a>
          {% endfor %}
        </nav>
      </div>

      {% if section.settings.show_newsletter %}
        <div>
          <p
            id="newsletter-heading"
            class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4"
          >
            {{ 'footer.newsletter_heading' | t }}
          </p>
          <p class="text-sm text-gray-500 mb-3">{{ 'footer.newsletter_text' | t }}</p>
          {% form 'customer' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {% if form.posted_successfully? %}
              <p class="bg-green-50 text-green-700 text-sm rounded-lg px-3 py-2 mb-3" role="status">
                {{ 'newsletter.success' | t }}
              </p>
            {% endif %}
            {% if form.errors %}
              <p class="bg-red-50 text-red-600 text-sm rounded-lg px-3 py-2 mb-3" role="alert">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </p>
            {% endif %}
            <div class="flex gap-2">
              <label for="newsletter-email" class="visually-hidden">
                {{- 'newsletter.label' | t -}}
              </label>
              <input
                type="email"
                id="newsletter-email"
                name="contact[email]"
                placeholder="{{ 'newsletter.placeholder' | t }}"
                required
                aria-required="true"
                autocomplete="email"
                class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              >
              <button
                type="submit"
                class="bg-gray-900 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer"
              >
                {{ 'newsletter.submit' | t }}
              </button>
            </div>
          {% endform %}
        </div>
      {% endif %}
    </div>

    <div class="border-t border-gray-200 pt-8 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-sm text-gray-400">
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name }}.
        {{ 'footer.rights' | t }}
      </p>
      <p class="text-sm text-gray-400">
        Shopify theme by
        <a
          href="https://www.codersy.com"
          class="text-gray-500 hover:text-gray-700 no-underline"
          title="Codersy - Shopify Development"
          >Codersy</a
        >
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "about_text",
      "label": "About text"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    }
  ]
}
{% endschema %}
