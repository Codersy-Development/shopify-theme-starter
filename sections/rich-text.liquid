<section class="py-12 md:py-16">
  <div class="page-width {{ section.settings.width }}">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'heading' %}
          <{{ block.settings.tag }}
            class="font-bold mb-4 {% if section.settings.center %}text-center{% endif %} {% if block.settings.size == 'small' %}text-xl sm:text-2xl{% elsif block.settings.size == 'large' %}text-3xl sm:text-4xl lg:text-5xl{% else %}text-2xl sm:text-3xl{% endif %}"
            style="font-family: var(--font-heading);"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </{{ block.settings.tag }}>

        {% when 'text' %}
          <div
            class="prose max-w-none text-[var(--color-text-light)] mb-6 {% if section.settings.center %}mx-auto text-center{% endif %} {% if block.settings.width == 'narrow' %}max-w-2xl{% elsif block.settings.width == 'medium' %}max-w-4xl{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.richtext }}
          </div>

        {% when 'button' %}
          <div class="{% if section.settings.center %}text-center{% endif %} mt-2 mb-6" {{ block.shopify_attributes }}>
            <a
              href="{{ block.settings.link }}"
              class="inline-block font-semibold text-sm px-8 py-3 rounded-lg no-underline transition-colors {% if block.settings.style == 'primary' %}bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)]{% elsif block.settings.style == 'outline' %}border-2 border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white{% else %}text-[var(--color-primary)] underline hover:text-[var(--color-primary-light)]{% endif %}"
            >
              {{ block.settings.label }}
            </a>
          </div>

        {% when 'spacer' %}
          <div
            class="{% if block.settings.height == 'small' %}h-4{% elsif block.settings.height == 'large' %}h-12{% else %}h-8{% endif %}"
            {{ block.shopify_attributes }}
          ></div>

        {% when 'divider' %}
          <hr class="border-[var(--color-border)] my-8" {{ block.shopify_attributes }}>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "center",
      "label": "Center content",
      "default": true
    },
    {
      "type": "select",
      "id": "width",
      "label": "Content width",
      "options": [
        { "value": "max-w-2xl mx-auto", "label": "Narrow" },
        { "value": "max-w-4xl mx-auto", "label": "Medium" },
        { "value": "", "label": "Full" }
      ],
      "default": "max-w-4xl mx-auto"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "medium"
        },
        {
          "type": "select",
          "id": "tag",
          "label": "HTML tag",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "p", "label": "Paragraph" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "richtext",
          "label": "Text",
          "default": "<p>Share information about your brand with your customers.</p>"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Text width",
          "options": [
            { "value": "narrow", "label": "Narrow" },
            { "value": "medium", "label": "Medium" },
            { "value": "full", "label": "Full" }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Filled" },
            { "value": "outline", "label": "Outline" },
            { "value": "link", "label": "Link" }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        {
          "type": "select",
          "id": "height",
          "label": "Height",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "divider",
      "name": "Divider"
    }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "blocks": [
        { "type": "heading", "settings": { "text": "Talk about your brand" } },
        { "type": "text", "settings": { "richtext": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>" } },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
