<section class="py-12">
  <div class="page-width max-w-3xl">
    <h1 class="text-3xl font-bold mb-8" style="font-family: var(--font-heading);">Your Cart</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post">
        <div class="divide-y divide-[var(--color-border)]">
          {% for item in cart.items %}
            <div class="flex items-center gap-4 py-6">
              <div class="w-20 h-20 bg-[var(--color-background-alt)] rounded-lg overflow-hidden shrink-0">
                {% render 'image',
                  image: item.image,
                  max_width: 200,
                  sizes: '80px',
                  alt: item.product.title,
                  class: 'w-full h-full object-cover'
                %}
              </div>

              <div class="flex-1 min-w-0">
                <a href="{{ item.url }}" class="text-sm font-medium text-[var(--color-text)] no-underline hover:text-[var(--color-primary)]">
                  {{ item.product.title }}
                </a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="text-sm text-[var(--color-text-light)] mt-1">{{ item.variant.title }}</p>
                {% endif %}
                <p class="text-sm text-[var(--color-text-light)] mt-1">{{ item.price | money }}</p>
              </div>

              <div class="flex items-center gap-2">
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  class="w-16 border border-[var(--color-border)] rounded-lg px-2 py-1 text-center text-sm"
                >
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="border-t border-[var(--color-border)] pt-6 mt-6">
          <div class="flex items-center justify-between mb-6">
            <span class="text-lg font-semibold">Total</span>
            <span class="text-lg font-semibold">{{ cart.total_price | money }}</span>
          </div>

          <div class="flex flex-col gap-3">
            <button
              type="submit"
              name="update"
              class="w-full border border-[var(--color-border)] font-semibold px-8 py-3 rounded-lg hover:bg-[var(--color-background-alt)] transition-colors cursor-pointer"
            >
              Update cart
            </button>
            <button
              type="submit"
              name="checkout"
              class="w-full bg-[var(--color-primary)] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[var(--color-primary-light)] transition-colors cursor-pointer"
            >
              Checkout
            </button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="text-center py-12">
        <p class="text-[var(--color-text-light)] mb-6">Your cart is empty.</p>
        <a
          href="/collections/all"
          class="inline-block bg-[var(--color-primary)] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[var(--color-primary-light)] transition-colors no-underline"
        >
          Continue shopping
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section"
}
{% endschema %}
