<header class="bg-white border-b border-gray-200" role="banner">
  <div class="page-width">
    <div class="flex items-center h-16 gap-4">
      <!-- Left: mobile menu + logo -->
      <div class="flex items-center gap-3 flex-1">
        {% render 'header-drawer', menu: section.settings.menu %}

        <a href="/" class="text-xl font-bold text-gray-900 no-underline shrink-0" title="{{ shop.name }}">
          {% if settings.logo != blank %}
            {% assign logo_sizes = settings.logo_max_width | append: 'px' %}
            {% assign logo_style = 'max-width: ' | append: settings.logo_max_width | append: 'px' %}
            {% render 'image',
              image: settings.logo,
              max_width: settings.logo_max_width,
              sizes: logo_sizes,
              alt: shop.name,
              loading: 'eager',
              style: logo_style
            %}
          {% else %}
            {{ shop.name }}
          {% endif %}
        </a>
      </div>

      <!-- Center: nav (desktop only) -->
      <header-nav
        class="hidden md:flex items-center justify-center gap-6 contents-on-mobile"
        aria-label="Main navigation"
      >
        <nav class="hidden md:flex items-center justify-center gap-6" aria-label="Main navigation">
          {% for link in linklists[section.settings.menu].links %}
            {% liquid
              assign has_children = false
              if link.links.size > 0
                assign has_children = true
              endif

              assign is_mega = false
              for block in section.blocks
                if block.type == 'mega_menu' and block.settings.menu_item == link.title
                  assign is_mega = true
                  assign mega_block = block
                  break
                endif
              endfor
            %}

            {% if is_mega %}
              {%- comment -%} Mega menu item {%- endcomment -%}
              <div class="header-nav-item" data-nav-item>
                <button
                  type="button"
                  class="text-sm text-gray-700 hover:text-gray-900 whitespace-nowrap inline-flex items-center gap-1 cursor-pointer bg-transparent border-0 p-0"
                  aria-expanded="false"
                  data-nav-trigger
                >
                  {{ link.title }}
                  <svg
                    class="w-3 h-3 transition-transform header-nav-chevron"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <div class="header-mega-menu" data-nav-panel>
                  <div class="page-width py-8">
                    <div class="flex gap-8">
                      {%- comment -%} Link columns {%- endcomment -%}
                      <div class="flex-1 grid grid-cols-{{ link.links.size | at_most: 4 }} gap-8">
                        {% for child in link.links %}
                          <div>
                            <a
                              href="{{ child.url }}"
                              class="text-sm font-semibold text-gray-900 no-underline block mb-3"
                            >
                              {{ child.title }}
                            </a>
                            {% if child.links.size > 0 %}
                              <ul class="list-none p-0 m-0 space-y-2">
                                {% for grandchild in child.links %}
                                  <li>
                                    <a
                                      href="{{ grandchild.url }}"
                                      class="text-sm text-gray-600 hover:text-gray-900 no-underline"
                                    >
                                      {{ grandchild.title }}
                                    </a>
                                  </li>
                                {% endfor %}
                              </ul>
                            {% endif %}
                          </div>
                        {% endfor %}
                      </div>

                      {%- comment -%} Featured image {%- endcomment -%}
                      {% if mega_block.settings.featured_image != blank %}
                        <div class="w-64 shrink-0">
                          <a href="{{ mega_block.settings.featured_image_link }}" class="block no-underline group">
                            {% render 'image',
                              image: mega_block.settings.featured_image,
                              sizes: '256px',
                              alt: mega_block.settings.featured_image_heading,
                              class: 'w-full aspect-[4/3] object-cover rounded-lg'
                            %}
                            {% if mega_block.settings.featured_image_heading != blank %}
                              <p class="mt-2 text-sm font-medium text-gray-900 group-hover:underline">
                                {{ mega_block.settings.featured_image_heading }}
                              </p>
                            {% endif %}
                          </a>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>

            {% elsif has_children %}
              {%- comment -%} Standard dropdown {%- endcomment -%}
              <div class="header-nav-item" data-nav-item>
                <button
                  type="button"
                  class="text-sm text-gray-700 hover:text-gray-900 whitespace-nowrap inline-flex items-center gap-1 cursor-pointer bg-transparent border-0 p-0"
                  aria-expanded="false"
                  data-nav-trigger
                >
                  {{ link.title }}
                  <svg
                    class="w-3 h-3 transition-transform header-nav-chevron"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <div class="header-dropdown" data-nav-panel>
                  <ul class="list-none p-0 m-0 py-2">
                    {% for child in link.links %}
                      <li>
                        <a
                          href="{{ child.url }}"
                          class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900 no-underline whitespace-nowrap"
                        >
                          {{ child.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>

            {% else %}
              <a
                href="{{ link.url }}"
                class="text-sm text-gray-700 hover:text-gray-900 no-underline whitespace-nowrap"
                {% if link.active %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title }}
              </a>
            {% endif %}
          {% endfor %}
        </nav>
      </header-nav>

      <!-- Right: icons -->
      <div class="flex items-center justify-end gap-4 flex-1">
        {% if settings.predictive_search_enabled %}
          {% render 'predictive-search' %}
        {% else %}
          <a href="/search" class="text-gray-700 hover:text-gray-900 no-underline" aria-label="Search">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </a>
        {% endif %}

        <cart-icon class="contents">
          {% if settings.cart_type == 'drawer' %}
            <button
              type="button"
              class="text-gray-700 hover:text-gray-900 cursor-pointer relative"
              onclick="document.dispatchEvent(new CustomEvent('cart:open'))"
              aria-label="Cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              <span
                data-cart-count
                class="absolute -top-2 -right-2 bg-gray-900 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
                aria-hidden="true"
              >
                {{ cart.item_count }}
              </span>
            </button>
          {% else %}
            <a
              href="/cart"
              class="text-gray-700 hover:text-gray-900 no-underline relative"
              aria-label="Cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              <span
                data-cart-count
                class="absolute -top-2 -right-2 bg-gray-900 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
                aria-hidden="true"
              >
                {{ cart.item_count }}
              </span>
            </a>
          {% endif %}
        </cart-icon>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega menu",
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "Menu item title",
          "info": "Enter the exact title of the top-level menu item to display as a mega menu."
        },
        {
          "type": "image_picker",
          "id": "featured_image",
          "label": "Featured image"
        },
        {
          "type": "text",
          "id": "featured_image_heading",
          "label": "Featured image heading"
        },
        {
          "type": "url",
          "id": "featured_image_link",
          "label": "Featured image link"
        }
      ]
    }
  ]
}
{% endschema %}
