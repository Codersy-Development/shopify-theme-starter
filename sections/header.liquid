<header class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="text-xl font-bold text-gray-900 no-underline">
        {{ shop.name }}
      </a>

      <nav class="hidden md:flex items-center gap-6">
        {% for link in linklists[section.settings.menu].links %}
          <a href="{{ link.url }}" class="text-sm text-gray-700 hover:text-gray-900 no-underline">
            {{ link.title }}
          </a>
        {% endfor %}
      </nav>

      <div class="flex items-center gap-4">
        <a href="/cart" class="text-sm text-gray-700 hover:text-gray-900 no-underline">
          Cart ({{ cart.item_count }})
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
