<header class="bg-white border-b border-gray-200" role="banner">
  <div class="page-width">
    <div class="flex items-center h-16 gap-4">
      <!-- Left: mobile menu + logo -->
      <div class="flex items-center gap-3 flex-1">
        {% render 'header-drawer', menu: section.settings.menu %}

        <a href="/" class="text-xl font-bold text-gray-900 no-underline shrink-0" title="{{ shop.name }}">
          {% if settings.logo != blank %}
            <img
              src="{{ settings.logo | image_url: width: settings.logo_max_width }}"
              alt="{{ shop.name }}"
              style="max-width: {{ settings.logo_max_width }}px"
              width="{{ settings.logo_max_width }}"
              height="{{ settings.logo_max_width | divided_by: settings.logo.aspect_ratio | round }}"
            >
          {% else %}
            {{ shop.name }}
          {% endif %}
        </a>
      </div>

      <!-- Center: nav (desktop only) -->
      <nav class="hidden md:flex items-center justify-center gap-6" aria-label="Main navigation">
        {% for link in linklists[section.settings.menu].links %}
          <a
            href="{{ link.url }}"
            class="text-sm text-gray-700 hover:text-gray-900 no-underline whitespace-nowrap"
            {% if link.active %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {% endfor %}
      </nav>

      <!-- Right: icons -->
      <div class="flex items-center justify-end gap-4 flex-1">
        {% if settings.predictive_search_enabled %}
          {% render 'predictive-search' %}
          <a href="/search" class="md:hidden text-gray-700 hover:text-gray-900 no-underline" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </a>
        {% else %}
          <a href="/search" class="text-gray-700 hover:text-gray-900 no-underline" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </a>
        {% endif %}

        <cart-icon>
          {% if settings.cart_type == 'drawer' %}
            <button
              type="button"
              class="text-gray-700 hover:text-gray-900 cursor-pointer relative"
              onclick="document.dispatchEvent(new CustomEvent('cart:open'))"
              aria-label="Cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              <span
                data-cart-count
                class="absolute -top-2 -right-2 bg-gray-900 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
                aria-hidden="true"
              >
                {{ cart.item_count }}
              </span>
            </button>
          {% else %}
            <a
              href="/cart"
              class="text-gray-700 hover:text-gray-900 no-underline relative"
              aria-label="Cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              <span
                data-cart-count
                class="absolute -top-2 -right-2 bg-gray-900 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
                aria-hidden="true"
              >
                {{ cart.item_count }}
              </span>
            </a>
          {% endif %}
        </cart-icon>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
