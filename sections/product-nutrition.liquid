<section class="py-12 md:py-16">
  <div class="page-width max-w-2xl">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-8" style="font-family: var(--font-heading);">
      {{ section.settings.heading }}
    </h2>

    <div class="border border-[var(--color-border)] rounded-xl overflow-hidden">
      <!-- Header -->
      <div class="bg-[var(--color-accent)] text-white px-6 py-4">
        <h3 class="text-lg font-bold">Supplement Facts</h3>
        {% if section.settings.serving_size != blank %}
          <p class="text-sm text-white/80">Serving Size: {{ section.settings.serving_size }}</p>
        {% endif %}
        {% if section.settings.servings_per_container != blank %}
          <p class="text-sm text-white/80">Servings Per Container: {{ section.settings.servings_per_container }}</p>
        {% endif %}
      </div>

      <!-- Table header -->
      <div class="flex items-center justify-between px-6 py-2 bg-[var(--color-background-alt)] border-b border-[var(--color-border)] text-xs font-semibold text-[var(--color-text-light)] uppercase tracking-wider">
        <span>Amount per serving</span>
        <span>% Daily Value</span>
      </div>

      <!-- Rows -->
      {% for block in section.blocks %}
        <div class="flex items-center justify-between px-6 py-3 border-b border-[var(--color-border)] last:border-b-0" {{ block.shopify_attributes }}>
          <div>
            <span class="text-sm font-semibold text-[var(--color-text)]">{{ block.settings.nutrient }}</span>
            {% if block.settings.amount != blank %}
              <span class="text-sm text-[var(--color-text-light)] ml-2">{{ block.settings.amount }}</span>
            {% endif %}
          </div>
          <span class="text-sm font-semibold text-[var(--color-text)]">{{ block.settings.daily_value }}</span>
        </div>
      {% endfor %}

      <!-- Other ingredients -->
      {% if section.settings.other_ingredients != blank %}
        <div class="px-6 py-4 border-t-2 border-[var(--color-border)] bg-[var(--color-background-alt)]">
          <p class="text-xs text-[var(--color-text-light)]">
            <strong>Other Ingredients:</strong> {{ section.settings.other_ingredients }}
          </p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nutrition Facts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nutrition Facts"
    },
    {
      "type": "text",
      "id": "serving_size",
      "label": "Serving size",
      "default": "2 capsules"
    },
    {
      "type": "text",
      "id": "servings_per_container",
      "label": "Servings per container",
      "default": "30"
    },
    {
      "type": "textarea",
      "id": "other_ingredients",
      "label": "Other ingredients",
      "default": "Vegetable cellulose (capsule), organic rice flour, silica."
    }
  ],
  "blocks": [
    {
      "type": "nutrient",
      "name": "Nutrient",
      "settings": [
        {
          "type": "text",
          "id": "nutrient",
          "label": "Nutrient name",
          "default": "Vitamin D3"
        },
        {
          "type": "text",
          "id": "amount",
          "label": "Amount",
          "default": "50mcg (2000 IU)"
        },
        {
          "type": "text",
          "id": "daily_value",
          "label": "% Daily value",
          "default": "250%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nutrition Facts",
      "blocks": [
        { "type": "nutrient", "settings": { "nutrient": "Vitamin D3", "amount": "50mcg (2000 IU)", "daily_value": "250%" } },
        { "type": "nutrient", "settings": { "nutrient": "Vitamin K2", "amount": "120mcg", "daily_value": "100%" } },
        { "type": "nutrient", "settings": { "nutrient": "Calcium", "amount": "500mg", "daily_value": "38%" } }
      ]
    }
  ]
}
{% endschema %}
