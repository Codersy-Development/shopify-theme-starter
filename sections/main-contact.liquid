<section class="py-12">
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold mb-4">{{ page.title }}</h1>

    {% if page.content != blank %}
      <div class="prose text-gray-600 mb-8">
        {{ page.content }}
      </div>
    {% endif %}

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="bg-green-50 text-green-700 text-sm rounded-lg px-4 py-3 mb-6">
          Thanks for your message! We'll get back to you as soon as possible.
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="bg-red-50 text-red-600 text-sm rounded-lg px-4 py-3 mb-6" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="space-y-4">
        <div>
          <label for="contact-name" class="block text-sm font-medium text-gray-700 mb-1">Name <span aria-hidden="true">*</span></label>
          <input
            type="text"
            id="contact-name"
            name="contact[name]"
            value="{% if form.name %}{{ form.name }}{% endif %}"
            required
            aria-required="true"
            autocomplete="name"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
          >
        </div>

        <div>
          <label for="contact-email" class="block text-sm font-medium text-gray-700 mb-1">Email <span aria-hidden="true">*</span></label>
          <input
            type="email"
            id="contact-email"
            name="contact[email]"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            required
            aria-required="true"
            autocomplete="email"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
          >
        </div>

        <div>
          <label for="contact-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone (optional)</label>
          <input
            type="tel"
            id="contact-phone"
            name="contact[phone]"
            value="{% if form.phone %}{{ form.phone }}{% endif %}"
            autocomplete="tel"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
          >
        </div>

        <div>
          <label for="contact-body" class="block text-sm font-medium text-gray-700 mb-1">Message <span aria-hidden="true">*</span></label>
          <textarea
            id="contact-body"
            name="contact[body]"
            rows="5"
            required
            aria-required="true"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent resize-y"
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-gray-900 text-white font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer"
        >
          Send message
        </button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section"
}
{% endschema %}
