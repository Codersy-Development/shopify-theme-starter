<section class="py-8 md:py-12">
  <div class="page-width">
    {% render 'breadcrumbs' %}

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Product Gallery -->
      <product-gallery class="block">
        {% if product.images.size > 0 %}
          <div class="relative aspect-square bg-gray-100 rounded-lg overflow-hidden" data-main-image>
            {% for image in product.images %}
              <div
                class="absolute inset-0 {% if forloop.first %}is-active{% endif %}"
                data-image-slide
                data-image-id="{{ image.id }}"
              >
                {% if forloop.first %}
                  {% render 'image',
                    image: image,
                    max_width: 1200,
                    widths: '400, 800, 1000, 1200',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: product.title,
                    loading: 'eager',
                    fetchpriority: 'high',
                    class: 'w-full h-full object-cover'
                  %}
                {% else %}
                  {% render 'image',
                    image: image,
                    max_width: 1200,
                    widths: '400, 800, 1000, 1200',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: product.title,
                    class: 'w-full h-full object-cover'
                  %}
                {% endif %}
              </div>
            {% endfor %}
          </div>

          {% if product.images.size > 1 %}
            <div class="flex gap-2 mt-3 overflow-x-auto" data-thumbnails role="listbox" aria-label="Product images">
              {% for image in product.images %}
                <button
                  type="button"
                  class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 bg-gray-100 rounded overflow-hidden border-2 transition-colors cursor-pointer {% if forloop.first %}border-gray-900{% else %}border-transparent{% endif %}"
                  data-thumbnail
                  data-target="{{ image.id }}"
                  role="option"
                  {% if forloop.first %}aria-selected="true"{% else %}aria-selected="false"{% endif %}
                  aria-label="Product image {{ forloop.index }}"
                >
                  {% render 'image',
                    image: image,
                    max_width: 200,
                    widths: '100, 150, 200',
                    sizes: '80px',
                    alt: product.title,
                    class: 'w-full h-full object-cover'
                  %}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <div class="aspect-square bg-gray-100 rounded-lg"></div>
        {% endif %}

        <script type="application/json" data-product-variants>
          {{ product.variants | json }}
        </script>
      </product-gallery>

      <!-- Product Info -->
      <div>
        <h1 class="text-3xl font-bold mb-4">{{ product.title }}</h1>
        <p class="text-2xl text-gray-700 mb-6">{{ product.price | money }}</p>

        {% if product.description != blank %}
          <div class="prose text-gray-600 mb-8">
            {{ product.description }}
          </div>
        {% endif %}

        <product-form>
          {% form 'product', product %}
            {% if product.variants.size > 1 %}
              <div class="mb-6">
                {% for option in product.options_with_values %}
                  <label class="block text-sm font-medium text-gray-700 mb-2">
                    {{ option.name }}
                  </label>
                  <select
                    name="id"
                    class="block w-full border border-gray-300 rounded-lg px-4 py-2 mb-4"
                  >
                    {% for variant in product.variants %}
                      <option
                        value="{{ variant.id }}"
                        {% if variant == product.selected_or_first_available_variant %}
                          selected
                        {% endif %}
                      >
                        {{ variant.title }} — {{ variant.price | money }}
                      </option>
                    {% endfor %}
                  </select>
                {% endfor %}
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {% endif %}

            <button
              type="submit"
              class="w-full bg-gray-900 text-white font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {% if product.available %}
                Add to cart
              {% else %}
                Sold out
              {% endif %}
            </button>
          {% endform %}
        </product-form>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section"
}
{% endschema %}
