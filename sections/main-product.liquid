<section class="py-8 md:py-12">
  <div class="page-width">
    {% render 'breadcrumbs' %}

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Product Gallery -->
      <product-gallery class="block">
        {% if product.images.size > 0 %}
          <div class="relative aspect-square bg-[var(--color-background-alt)] rounded-xl overflow-hidden" data-main-image>
            {% for image in product.images %}
              <div
                class="absolute inset-0 {% if forloop.first %}is-active{% endif %}"
                data-image-slide
                data-image-id="{{ image.id }}"
              >
                {% if forloop.first %}
                  {% render 'image',
                    image: image,
                    max_width: 1200,
                    widths: '400, 800, 1000, 1200',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: product.title,
                    loading: 'eager',
                    fetchpriority: 'high',
                    class: 'w-full h-full object-cover'
                  %}
                {% else %}
                  {% render 'image',
                    image: image,
                    max_width: 1200,
                    widths: '400, 800, 1000, 1200',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: product.title,
                    class: 'w-full h-full object-cover'
                  %}
                {% endif %}
              </div>
            {% endfor %}
          </div>

          {% if product.images.size > 1 %}
            <div class="flex gap-2 mt-3 overflow-x-auto" data-thumbnails role="listbox" aria-label="Product images">
              {% for image in product.images %}
                <button
                  type="button"
                  class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 bg-[var(--color-background-alt)] rounded-lg overflow-hidden border-2 transition-colors cursor-pointer {% if forloop.first %}border-[var(--color-primary)]{% else %}border-transparent{% endif %}"
                  data-thumbnail
                  data-target="{{ image.id }}"
                  role="option"
                  {% if forloop.first %}aria-selected="true"{% else %}aria-selected="false"{% endif %}
                  aria-label="Product image {{ forloop.index }}"
                >
                  {% render 'image',
                    image: image,
                    max_width: 200,
                    widths: '100, 150, 200',
                    sizes: '80px',
                    alt: product.title,
                    class: 'w-full h-full object-cover'
                  %}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <div class="aspect-square bg-[var(--color-background-alt)] rounded-xl"></div>
        {% endif %}

        <script type="application/json" data-product-variants>
          {{ product.variants | json }}
        </script>
      </product-gallery>

      <!-- Product Info -->
      <div>
        <h1 class="text-3xl font-bold mb-2" style="font-family: var(--font-heading);">{{ product.title }}</h1>

        {% if product.metafields.custom.subtitle %}
          <p class="text-[var(--color-text-light)] mb-4">{{ product.metafields.custom.subtitle }}</p>
        {% endif %}

        <div class="flex items-baseline gap-3 mb-6">
          <span class="text-2xl font-bold text-[var(--color-primary)]">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="text-lg text-[var(--color-text-light)] line-through">{{ product.compare_at_price | money }}</span>
            <span class="text-sm font-semibold bg-red-100 text-red-700 px-2 py-0.5 rounded">
              Save {{ product.compare_at_price | minus: product.price | money }}
            </span>
          {% endif %}
        </div>

        <!-- Subscription Toggle -->
        {% if section.settings.show_subscription_toggle %}
          <subscription-toggle class="block mb-6">
            <div class="border border-[var(--color-border)] rounded-xl overflow-hidden">
              <label class="flex items-center gap-3 p-4 cursor-pointer border-b border-[var(--color-border)] bg-[var(--color-background)]" data-purchase-type="onetime">
                <input type="radio" name="purchase_type" value="onetime" checked class="accent-[var(--color-primary)]">
                <div class="flex-1">
                  <span class="text-sm font-semibold">One-time purchase</span>
                  <span class="text-sm text-[var(--color-text-light)] ml-2">{{ product.price | money }}</span>
                </div>
              </label>
              <label class="flex items-center gap-3 p-4 cursor-pointer bg-[var(--color-background-alt)]" data-purchase-type="subscription">
                <input type="radio" name="purchase_type" value="subscription" class="accent-[var(--color-primary)]">
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold">Subscribe & save {{ section.settings.subscription_discount }}%</span>
                    <span class="text-xs font-semibold bg-[var(--color-primary)] text-white px-2 py-0.5 rounded-full">Best value</span>
                  </div>
                  <span class="text-sm text-[var(--color-text-light)]">
                    {%- assign discount_multiplier = 100 | minus: section.settings.subscription_discount -%}
                    {%- assign sub_price = product.price | times: discount_multiplier | divided_by: 100 -%}
                    {{ sub_price | money }} — delivered every {{ section.settings.subscription_frequency }}
                  </span>
                </div>
              </label>
            </div>
          </subscription-toggle>
        {% endif %}

        <!-- Product Form -->
        <product-form>
          {% form 'product', product %}
            {% if product.variants.size > 1 %}
              <div class="mb-6">
                {% for option in product.options_with_values %}
                  <label class="block text-sm font-medium text-[var(--color-text)] mb-2">{{ option.name }}</label>
                  <select
                    name="id"
                    class="block w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 mb-4 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
                  >
                    {% for variant in product.variants %}
                      <option
                        value="{{ variant.id }}"
                        {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                      >
                        {{ variant.title }} — {{ variant.price | money }}
                      </option>
                    {% endfor %}
                  </select>
                {% endfor %}
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {% endif %}

            <button
              type="submit"
              class="w-full bg-[var(--color-primary)] text-white font-semibold px-8 py-4 rounded-xl hover:bg-[var(--color-primary-light)] transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed text-lg"
              {% unless product.available %}disabled{% endunless %}
            >
              {% if product.available %}
                Add to cart
              {% else %}
                Sold out
              {% endif %}
            </button>
          {% endform %}
        </product-form>

        <!-- Product Trust Badges -->
        {% if section.settings.show_trust_badges %}
          <div class="mt-6 grid grid-cols-2 gap-3">
            {% for block in section.blocks %}
              {% if block.type == 'trust_badge' %}
                <div class="flex items-center gap-2 text-sm text-[var(--color-text-light)]" {{ block.shopify_attributes }}>
                  <svg class="w-5 h-5 text-[var(--color-primary)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  {{ block.settings.text }}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        <!-- Product Description -->
        {% if product.description != blank %}
          <div class="mt-8 pt-8 border-t border-[var(--color-border)]">
            <div class="prose text-[var(--color-text-light)] max-w-none">
              {{ product.description }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Subscription"
    },
    {
      "type": "checkbox",
      "id": "show_subscription_toggle",
      "label": "Show subscription toggle",
      "default": true,
      "info": "Displays a one-time vs subscribe & save toggle."
    },
    {
      "type": "range",
      "id": "subscription_discount",
      "label": "Subscription discount %",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "select",
      "id": "subscription_frequency",
      "label": "Default frequency",
      "options": [
        { "value": "2 weeks", "label": "Every 2 weeks" },
        { "value": "month", "label": "Every month" },
        { "value": "2 months", "label": "Every 2 months" },
        { "value": "3 months", "label": "Every 3 months" }
      ],
      "default": "month"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "GMP Certified"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "trust_badge", "settings": { "text": "GMP Certified" } },
      { "type": "trust_badge", "settings": { "text": "Third-Party Tested" } },
      { "type": "trust_badge", "settings": { "text": "Non-GMO" } },
      { "type": "trust_badge", "settings": { "text": "Free Returns" } }
    ]
  }
}
{% endschema %}
