<section class="py-8 md:py-12">
  <div class="page-width">
    {% render 'breadcrumbs' %}

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Product Gallery -->
      <product-gallery class="block">
        {% if product.images.size > 0 %}
          <div
            class="relative aspect-square bg-gray-100 rounded-lg overflow-hidden"
            data-main-image
          >
            {% for image in product.images %}
              <div
                class="absolute inset-0 {% if forloop.first %}is-active{% endif %}"
                data-image-slide
                data-image-id="{{ image.id }}"
              >
                {% if forloop.first %}
                  {% render 'image',
                    image: image,
                    max_width: 1200,
                    widths: '400, 800, 1000, 1200',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: product.title,
                    loading: 'eager',
                    fetchpriority: 'high',
                    class: 'w-full h-full object-cover'
                  %}
                {% else %}
                  {% render 'image',
                    image: image,
                    max_width: 1200,
                    widths: '400, 800, 1000, 1200',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: product.title,
                    class: 'w-full h-full object-cover'
                  %}
                {% endif %}
              </div>
            {% endfor %}
          </div>

          {% if product.images.size > 1 %}
            <div
              class="flex gap-2 mt-3 overflow-x-auto"
              data-thumbnails
              role="listbox"
              aria-label="{{ 'products.product.gallery_label' | t }}"
            >
              {% for image in product.images %}
                <button
                  type="button"
                  class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 bg-gray-100 rounded overflow-hidden border-2 transition-colors cursor-pointer {% if forloop.first %}border-gray-900{% else %}border-transparent{% endif %}"
                  data-thumbnail
                  data-target="{{ image.id }}"
                  role="option"
                  {% if forloop.first %}
                    aria-selected="true"
                  {% else %}
                    aria-selected="false"
                  {% endif %}
                  aria-label="{{ 'products.product.image_label' | t: index: forloop.index }}"
                >
                  {% render 'image',
                    image: image,
                    max_width: 200,
                    widths: '100, 150, 200',
                    sizes: '80px',
                    alt: product.title,
                    class: 'w-full h-full object-cover'
                  %}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <div class="aspect-square bg-gray-100 rounded-lg"></div>
        {% endif %}

        <script type="application/json" data-product-variants>
          {{ product.variants | json }}
        </script>
      </product-gallery>

      <!-- Product Info -->
      <div>
        <h1 class="text-3xl font-bold mb-4">{{ product.title }}</h1>
        <p class="text-2xl text-gray-700 mb-6" data-product-price>
          {{ product.selected_or_first_available_variant.price | money }}
        </p>

        {% if product.description != blank %}
          <div class="prose text-gray-600 mb-8">
            {{ product.description }}
          </div>
        {% endif %}

        <product-form>
          {% form 'product', product %}
            {% if product.variants.size > 1 %}
              <div class="mb-6">
                <label
                  for="variant-select-{{ section.id }}"
                  class="block text-sm font-medium text-gray-700 mb-2"
                >
                  {{ product.options | join: ' / ' }}
                </label>
                <select
                  id="variant-select-{{ section.id }}"
                  name="id"
                  class="block w-full border border-gray-300 rounded-lg px-4 py-2"
                >
                  {% for variant in product.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-price="{{ variant.price | money }}"
                      {% unless variant.available %}
                        disabled
                      {% endunless %}
                      {% if variant == product.selected_or_first_available_variant %}
                        selected
                      {% endif %}
                    >
                      {{ variant.title }} — {{ variant.price | money -}}
                      {% unless variant.available %}
                        ({{ 'products.product.sold_out' | t }})
                      {%- endunless %}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input
                type="hidden"
                name="id"
                value="{{ product.selected_or_first_available_variant.id }}"
              >
            {% endif %}

            <button
              type="submit"
              class="w-full bg-gray-900 text-white font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {% if product.available %}
                {{ 'products.product.add_to_cart' | t }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>
          {% endform %}
        </product-form>
      </div>
    </div>
  </div>
</section>

<sticky-atc>
  <div
    data-bar
    data-visible="false"
    class="fixed bottom-0 inset-x-0 z-30 md:hidden bg-white border-t border-gray-200 shadow-lg translate-y-full data-[visible=true]:translate-y-0 transition-transform duration-200 ease-out"
    aria-hidden="true"
  >
    <div class="flex items-center gap-3 px-4 py-3">
      <div class="w-10 h-10 bg-gray-100 rounded-lg overflow-hidden shrink-0">
        {%- if product.featured_image -%}
          {% render 'image',
            image: product.featured_image,
            max_width: 80,
            sizes: '40px',
            alt: product.title,
            class: 'w-full h-full object-cover'
          %}
        {%- endif -%}
      </div>

      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate">{{ product.title }}</p>
        <p class="text-sm text-gray-600" data-product-price>
          {{ product.selected_or_first_available_variant.price | money }}
        </p>
      </div>

      <button
        type="button"
        data-add-to-cart
        class="bg-gray-900 text-white font-semibold px-4 py-2 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed shrink-0"
        {% unless product.available %}
          disabled
        {% endunless %}
      >
        {% if product.available %}
          {{ 'products.product.add_to_cart' | t }}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </button>
    </div>
  </div>
</sticky-atc>

{% schema %}
{
  "name": "Product",
  "tag": "section"
}
{% endschema %}
