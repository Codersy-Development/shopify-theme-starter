<section class="py-10 md:py-14 {% if section.settings.alt_background %}bg-[var(--color-background-alt)]{% endif %}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="text-xl sm:text-2xl font-bold text-center mb-8" style="font-family: var(--font-heading);">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
      {% for block in section.blocks %}
        <div class="flex flex-col items-center gap-2 text-center" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="w-16 h-16 md:w-20 md:h-20">
              {% render 'image',
                image: block.settings.image,
                max_width: 160,
                sizes: '80px',
                alt: block.settings.label,
                class: 'w-full h-full object-contain'
              %}
            </div>
          {% else %}
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center">
              <svg class="w-8 h-8 md:w-10 md:h-10 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
          {% endif %}
          {% if block.settings.label != blank %}
            <span class="text-xs font-semibold text-[var(--color-text-light)] uppercase tracking-wider">{{ block.settings.label }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Certification Badges",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quality You Can Trust"
    },
    {
      "type": "checkbox",
      "id": "alt_background",
      "label": "Alternate background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Badge image",
          "info": "Use a transparent PNG for best results."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "GMP Certified"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certification Badges",
      "blocks": [
        { "type": "badge", "settings": { "label": "GMP Certified" } },
        { "type": "badge", "settings": { "label": "Organic" } },
        { "type": "badge", "settings": { "label": "Non-GMO" } },
        { "type": "badge", "settings": { "label": "Vegan" } },
        { "type": "badge", "settings": { "label": "Third-Party Tested" } }
      ]
    }
  ]
}
{% endschema %}
