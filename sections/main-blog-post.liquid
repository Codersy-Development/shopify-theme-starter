<section class="py-12">
  <div class="page-width max-w-3xl">
    <h1 class="text-3xl font-bold mb-4" style="font-family: var(--font-heading);">{{ article.title }}</h1>
    <p class="text-sm text-[var(--color-text-light)] mb-8">
      {{ article.published_at | date: '%B %d, %Y' }} &middot; {{ article.author }}
    </p>

    <div class="prose prose-lg max-w-none">
      {{ article.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Post",
  "tag": "section"
}
{% endschema %}
