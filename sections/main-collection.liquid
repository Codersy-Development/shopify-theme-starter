{%- liquid
  assign per_page = section.settings.products_per_page | default: 24
-%}

{% paginate collection.products by per_page %}
  <section class="py-8 md:py-12">
    <div class="page-width">
      {% render 'breadcrumbs' %}

      <h1 class="text-3xl font-bold mb-2">{{ collection.title }}</h1>

      {% if collection.description != blank %}
        <div class="prose text-gray-600 mb-6">{{ collection.description }}</div>
      {% endif %}

      <collection-filters class="block">
        <!-- Mobile drawer overlay -->
        <div data-filter-overlay class="fixed inset-0 z-40 md:hidden"></div>

        <form action="{{ collection.url }}" method="get" data-filter-form>
          <!-- Toolbar -->
          <div class="flex items-center justify-between py-4 border-y border-gray-200 mb-6">
            <button
              type="button"
              data-toggle-filters
              class="flex items-center gap-2 text-sm font-medium uppercase tracking-wider cursor-pointer"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
                />
              </svg>
              <span data-filters-label>{{ 'collections.filters.show' | t }}</span>
            </button>

            <div class="flex items-center gap-4">
              <!-- Products per row (desktop) -->
              <grid-switcher
                class="hidden md:flex items-center gap-1"
                role="radiogroup"
                aria-label="{{ 'collections.grid.label' | t }}"
              >
                <button
                  type="button"
                  data-grid="3"
                  class="p-1.5 rounded hover:bg-gray-100 transition-colors cursor-pointer"
                  aria-label="{{ 'collections.grid.columns' | t: count: 3 }}"
                >
                  <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                    <rect x="1" y="2" width="5" height="16" rx="1"/><rect x="8" y="2" width="5" height="16" rx="1"/><rect x="15" y="2" width="4" height="16" rx="1"/>
                  </svg>
                </button>
                <button
                  type="button"
                  data-grid="4"
                  class="p-1.5 rounded hover:bg-gray-100 transition-colors cursor-pointer"
                  aria-label="{{ 'collections.grid.columns' | t: count: 4 }}"
                >
                  <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                    <rect x="1" y="2" width="3.5" height="16" rx="1"/><rect x="6" y="2" width="3.5" height="16" rx="1"/><rect x="11" y="2" width="3.5" height="16" rx="1"/><rect x="16" y="2" width="3" height="16" rx="1"/>
                  </svg>
                </button>
              </grid-switcher>

              <!-- Sort -->
              <div class="flex items-center gap-2">
                <label for="sort-by-select" class="text-sm text-gray-500 hidden sm:inline">
                  {{ 'collections.sorting.label' | t }}
                </label>
                <select
                  id="sort-by-select"
                  name="sort_by"
                  aria-label="{{ 'collections.sorting.label' | t }}"
                  class="text-sm font-medium border-0 bg-transparent cursor-pointer pr-6 focus:ring-0 focus:outline-none"
                >
                  {% for option in collection.sort_options %}
                    <option
                      value="{{ option.value }}"
                      {% if collection.sort_by == option.value %}
                        selected
                      {% endif %}
                    >
                      {{ option.name }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            </div>
          </div>

          <!-- Active filter tags -->
          {% assign active_filters_count = 0 %}
          {% for filter in collection.filters %}
            {% assign active_filters_count = active_filters_count
              | plus: filter.active_values.size
            %}
          {% endfor %}

          {% if active_filters_count > 0 %}
            <div class="flex flex-wrap items-center gap-2 mb-6">
              {% for filter in collection.filters %}
                {% for value in filter.active_values %}
                  <a
                    href="{{ value.url_to_remove }}"
                    class="inline-flex items-center gap-1 text-xs bg-gray-100 rounded-full px-3 py-1.5 no-underline text-gray-700 hover:bg-gray-200 transition-colors"
                  >
                    {{ value.label }}
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </a>
                {% endfor %}
              {% endfor %}
              <a
                href="{{ collection.url }}"
                class="text-xs text-gray-500 hover:text-gray-900 underline ml-1"
              >
                {{- 'collections.filters.clear_all' | t -}}
              </a>
            </div>
          {% endif %}

          <!-- Layout: sidebar / drawer + grid -->
          <div class="md:flex gap-8">
            <!-- Filters: mobile drawer / desktop sidebar -->
            <aside data-filters class="bg-white z-50 flex flex-col md:w-56 md:shrink-0 md:block">
              <!-- Mobile drawer header -->
              <div class="md:hidden flex items-center justify-between px-6 py-4 border-b border-gray-200">
                <span class="text-sm font-medium uppercase tracking-wider">
                  {{- 'collections.filters.title' | t -}}
                </span>
                <button
                  type="button"
                  data-close-filters
                  class="text-gray-400 hover:text-gray-600 cursor-pointer"
                  aria-label="{{ 'collections.filters.close' | t }}"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>

              <!-- Filter groups -->
              <div class="flex-1 overflow-y-auto px-6 md:px-0">
                {% for filter in collection.filters %}
                  <details
                    class="group border-b border-gray-200"
                    {% if forloop.index <= 3 %}
                      open
                    {% endif %}
                  >
                    <summary class="flex justify-between items-center py-4 cursor-pointer [&::-webkit-details-marker]:hidden list-none text-sm font-medium uppercase tracking-wider select-none">
                      {{ filter.label }}
                      <span class="text-gray-400 text-lg leading-none" aria-hidden="true">
                        <span class="group-open:hidden">+</span>
                        <span class="hidden group-open:inline">−</span>
                      </span>
                    </summary>

                    <div class="pb-4">
                      {% case filter.type %}
                        {% when 'list' %}
                          <div class="space-y-2 max-h-60 overflow-y-auto">
                            {% for value in filter.values %}
                              {% if value.count > 0 or value.active %}
                                <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700">
                                  <input
                                    type="checkbox"
                                    name="{{ value.param_name }}"
                                    value="{{ value.value }}"
                                    {% if value.active %}
                                      checked
                                    {% endif %}
                                    class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900 cursor-pointer"
                                  >
                                  <span class="flex-1">{{ value.label }}</span>
                                  <span class="text-gray-400 text-xs">({{ value.count }})</span>
                                </label>
                              {% endif %}
                            {% endfor %}
                          </div>

                        {% when 'price_range' %}
                          {%- liquid
                            # Filter values are in cents; divide instead of parsing
                            # money strings so locale formatting can't break the math.
                            assign range_max_money = filter.range_max | divided_by: 100.0 | ceil
                            assign min_money = filter.min_value.value | default: 0 | divided_by: 100.0 | floor
                            assign max_money = filter.max_value.value | default: filter.range_max | divided_by: 100.0 | ceil
                          -%}

                          <price-range-slider
                            data-range-max="{{ range_max_money }}"
                            data-currency="{{ cart.currency.symbol }}"
                            class="block"
                          >
                            <!-- Range slider -->
                            <div data-range-slider class="mx-1 mb-3">
                              <div data-range-track></div>
                              <div data-range-min></div>
                              <div data-range-max></div>
                            </div>
                            <div class="flex justify-between text-xs text-gray-500">
                              <span data-label-min>
                                {{- cart.currency.symbol -}}
                                {{- min_money | round -}}
                              </span>
                              <span data-label-max>
                                {{- cart.currency.symbol -}}
                                {{- max_money | round }}+</span
                              >
                            </div>

                            <!-- Hidden inputs submitted with form -->
                            <input
                              type="hidden"
                              name="{{ filter.min_value.param_name }}"
                              data-price-min
                              {% if filter.min_value.value %}
                                value="{{ min_money }}"
                              {% endif %}
                            >
                            <input
                              type="hidden"
                              name="{{ filter.max_value.param_name }}"
                              data-price-max
                              {% if filter.max_value.value %}
                                value="{{ max_money }}"
                              {% endif %}
                            >
                          </price-range-slider>

                        {% when 'boolean' %}
                          <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700">
                            <input
                              type="checkbox"
                              name="{{ filter.param_name }}"
                              value="1"
                              {% if filter.active_values.size > 0 %}
                                checked
                              {% endif %}
                              class="w-4 h-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900 cursor-pointer"
                            >
                            {{ filter.label }}
                          </label>
                      {% endcase %}
                    </div>
                  </details>
                {% endfor %}
              </div>

              <!-- Mobile drawer footer -->
              <div class="md:hidden flex gap-3 px-6 py-4 border-t border-gray-200">
                <a
                  href="{{ collection.url }}"
                  class="flex-1 text-center border border-gray-900 py-3 text-sm font-medium uppercase tracking-wider no-underline text-gray-900 hover:bg-gray-50 transition-colors"
                >
                  {{ 'collections.filters.clear_all' | t }}
                </a>
                <button
                  type="submit"
                  class="flex-1 bg-gray-900 text-white py-3 text-sm font-medium uppercase tracking-wider cursor-pointer hover:bg-gray-800 transition-colors"
                >
                  {{ 'collections.filters.apply' | t }}
                </button>
              </div>
            </aside>

            <!-- Product grid -->
            <div class="flex-1 min-w-0">
              {% if collection.products.size > 0 %}
                <p class="text-sm text-gray-500 mb-4">
                  {{ 'collections.products_count' | t: count: collection.products_count }}
                </p>
                <div data-product-grid class="grid grid-cols-2 md:grid-cols-3 gap-6">
                  {% for product in collection.products %}
                    {% render 'product-card',
                      product: product,
                      show_swatches: section.settings.show_swatches
                    %}
                  {% endfor %}
                </div>
              {% else %}
                <div class="text-center py-16">
                  <p class="text-gray-500 mb-4">{{ 'collections.filters.no_products' | t }}</p>
                  <a
                    href="{{ collection.url }}"
                    class="text-sm font-medium text-gray-900 underline"
                  >
                    {{- 'collections.filters.clear_all_filters' | t -}}
                  </a>
                </div>
              {% endif %}
            </div>
          </div>
        </form>

        {% render 'pagination', paginate: paginate %}
      </collection-filters>
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    }
  ]
}
{% endschema %}
