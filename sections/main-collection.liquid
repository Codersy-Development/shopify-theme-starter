{%- liquid
  assign per_page = section.settings.products_per_page | default: 24
-%}

{% paginate collection.products by per_page %}
<section class="py-8 md:py-12">
  <div class="page-width">
    {% render 'breadcrumbs' %}

    <h1 class="text-3xl font-bold mb-2" style="font-family: var(--font-heading);">{{ collection.title }}</h1>

    {% if collection.description != blank %}
      <div class="prose text-[var(--color-text-light)] mb-6">{{ collection.description }}</div>
    {% endif %}

    <collection-filters class="block">
      <!-- Mobile drawer overlay -->
      <div data-filter-overlay class="fixed inset-0 z-40 md:hidden"></div>

      <form action="{{ collection.url }}" method="get" data-filter-form>
        <!-- Toolbar -->
        <div class="flex items-center justify-between py-4 border-y border-[var(--color-border)] mb-6">
          <button
            type="button"
            data-toggle-filters
            class="flex items-center gap-2 text-sm font-medium uppercase tracking-wider cursor-pointer"
          >
            <span data-filters-label>Show Filters</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div class="flex items-center gap-4">
            <!-- Products per row (desktop) -->
            <div class="hidden md:flex items-center gap-1" role="radiogroup" aria-label="Grid columns">
              <button type="button" data-grid="3" class="p-1.5 rounded hover:bg-[var(--color-background-alt)] transition-colors cursor-pointer" aria-label="3 columns">
                <svg class="w-5 h-5 text-[var(--color-text-light)]" fill="currentColor" viewBox="0 0 20 20"><rect x="1" y="2" width="5" height="16" rx="1"/><rect x="8" y="2" width="5" height="16" rx="1"/><rect x="15" y="2" width="4" height="16" rx="1"/></svg>
              </button>
              <button type="button" data-grid="4" class="p-1.5 rounded hover:bg-[var(--color-background-alt)] transition-colors cursor-pointer" aria-label="4 columns">
                <svg class="w-5 h-5 text-[var(--color-text-light)]" fill="currentColor" viewBox="0 0 20 20"><rect x="1" y="2" width="3.5" height="16" rx="1"/><rect x="6" y="2" width="3.5" height="16" rx="1"/><rect x="11" y="2" width="3.5" height="16" rx="1"/><rect x="16" y="2" width="3" height="16" rx="1"/></svg>
              </button>
            </div>

            <!-- Sort -->
            <div class="flex items-center gap-2">
              <span class="text-sm text-[var(--color-text-light)] hidden sm:inline">Sort by:</span>
              <select
                name="sort_by"
                class="text-sm font-medium border-0 bg-transparent cursor-pointer pr-6 focus:ring-0 focus:outline-none"
              >
                {% for option in collection.sort_options %}
                  <option
                    value="{{ option.value }}"
                    {% if collection.sort_by == option.value %}selected{% endif %}
                  >
                    {{ option.name }}
                  </option>
                {% endfor %}
              </select>
            </div>
          </div>
        </div>

        <!-- Active filter tags -->
        {% assign active_filters_count = 0 %}
        {% for filter in collection.filters %}
          {% assign active_filters_count = active_filters_count | plus: filter.active_values.size %}
        {% endfor %}

        {% if active_filters_count > 0 %}
          <div class="flex flex-wrap items-center gap-2 mb-6">
            {% for filter in collection.filters %}
              {% for value in filter.active_values %}
                <a
                  href="{{ value.url_to_remove }}"
                  class="inline-flex items-center gap-1 text-xs bg-[var(--color-background-alt)] rounded-full px-3 py-1.5 no-underline text-[var(--color-text)] hover:bg-[var(--color-border)] transition-colors"
                >
                  {{ value.label }}
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </a>
              {% endfor %}
            {% endfor %}
            <a href="{{ collection.url }}" class="text-xs text-[var(--color-text-light)] hover:text-[var(--color-text)] no-underline underline ml-1">Clear all</a>
          </div>
        {% endif %}

        <!-- Layout: sidebar / drawer + grid -->
        <div class="md:flex gap-8">
          <!-- Filters: mobile drawer / desktop sidebar -->
          <aside data-filters class="bg-[var(--color-background)] z-50 flex flex-col md:w-56 md:shrink-0 md:block">
            <!-- Mobile drawer header -->
            <div class="md:hidden flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)]">
              <button
                type="button"
                data-toggle-filters
                class="flex items-center gap-2 text-sm font-medium uppercase tracking-wider cursor-pointer"
              >
                Hide Filter
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
                </svg>
              </button>
              <button type="button" data-close-filters class="text-[var(--color-text-light)] hover:text-[var(--color-text-light)] cursor-pointer" aria-label="Close filters">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" d="M5 12h14" />
                </svg>
              </button>
            </div>

            <!-- Filter groups -->
            <div class="flex-1 overflow-y-auto px-6 md:px-0">
              {% for filter in collection.filters %}
                <details class="group border-b border-[var(--color-border)]" {% if forloop.index <= 3 %}open{% endif %}>
                  <summary class="flex justify-between items-center py-4 cursor-pointer [&::-webkit-details-marker]:hidden list-none text-sm font-medium uppercase tracking-wider select-none">
                    {{ filter.label }}
                    <span class="text-[var(--color-text-light)] text-lg leading-none" aria-hidden="true">
                      <span class="group-open:hidden">+</span>
                      <span class="hidden group-open:inline">−</span>
                    </span>
                  </summary>

                  <div class="pb-4">
                    {% case filter.type %}
                      {% when 'list' %}
                        <div class="space-y-2 max-h-60 overflow-y-auto">
                          {% for value in filter.values %}
                            {% if value.count > 0 or value.active %}
                              <label class="flex items-center gap-2 cursor-pointer text-sm text-[var(--color-text)]">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  {% if value.active %}checked{% endif %}
                                  class="w-4 h-4 rounded border-[var(--color-border)] text-[var(--color-text)] focus:ring-[var(--color-primary)] cursor-pointer"
                                >
                                <span class="flex-1">{{ value.label }}</span>
                                <span class="text-[var(--color-text-light)] text-xs">({{ value.count }})</span>
                              </label>
                            {% endif %}
                          {% endfor %}
                        </div>

                      {% when 'price_range' %}
                        {%- liquid
                          assign range_max_money = filter.range_max | money_without_currency | replace: ',', ''
                          assign min_money = filter.min_value.value | default: 0 | money_without_currency | replace: ',', ''
                          assign max_money = filter.max_value.value | default: filter.range_max | money_without_currency | replace: ',', ''
                        -%}

                        <!-- Range slider -->
                        <div
                          data-range-slider
                          data-range-max="{{ range_max_money }}"
                          data-currency="{{ cart.currency.symbol }}"
                          class="mx-1 mb-3"
                        >
                          <div data-range-track></div>
                          <div data-range-min></div>
                          <div data-range-max></div>
                        </div>
                        <div class="flex justify-between text-xs text-[var(--color-text-light)]">
                          <span data-label-min>{{ cart.currency.symbol }}{{ min_money | round }}</span>
                          <span data-label-max>{{ cart.currency.symbol }}{{ max_money | round }}+</span>
                        </div>

                        <!-- Hidden inputs submitted with form -->
                        <input
                          type="hidden"
                          name="{{ filter.min_value.param_name }}"
                          data-price-min
                          {% if filter.min_value.value %}value="{{ min_money }}"{% endif %}
                        >
                        <input
                          type="hidden"
                          name="{{ filter.max_value.param_name }}"
                          data-price-max
                          {% if filter.max_value.value %}value="{{ max_money }}"{% endif %}
                        >

                      {% when 'boolean' %}
                        <label class="flex items-center gap-2 cursor-pointer text-sm text-[var(--color-text)]">
                          <input
                            type="checkbox"
                            name="{{ filter.param_name }}"
                            value="1"
                            {% if filter.active_values.size > 0 %}checked{% endif %}
                            class="w-4 h-4 rounded border-[var(--color-border)] text-[var(--color-text)] focus:ring-[var(--color-primary)] cursor-pointer"
                          >
                          {{ filter.label }}
                        </label>
                    {% endcase %}
                  </div>
                </details>
              {% endfor %}
            </div>

            <!-- Mobile drawer footer -->
            <div class="md:hidden flex gap-3 px-6 py-4 border-t border-[var(--color-border)]">
              <a
                href="{{ collection.url }}"
                class="flex-1 text-center border border-gray-900 py-3 text-sm font-medium uppercase tracking-wider no-underline text-[var(--color-text)] hover:bg-[var(--color-background-alt)] transition-colors"
              >
                Clear All
              </a>
              <button
                type="submit"
                class="flex-1 bg-[var(--color-primary)] text-white py-3 text-sm font-medium uppercase tracking-wider cursor-pointer hover:bg-[var(--color-primary-light)] transition-colors"
              >
                Apply
              </button>
            </div>
          </aside>

          <!-- Product grid -->
          <div class="flex-1 min-w-0">
            {% if collection.products.size > 0 %}
              <p class="text-sm text-[var(--color-text-light)] mb-4">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</p>
              <div data-product-grid class="grid grid-cols-2 md:grid-cols-3 gap-6">
                {% for product in collection.products %}
                  {% render 'product-card', product: product, show_swatches: section.settings.show_swatches %}
                {% endfor %}
              </div>
            {% else %}
              <div class="text-center py-16">
                <p class="text-[var(--color-text-light)] mb-4">No products match your filters.</p>
                <a href="{{ collection.url }}" class="text-sm font-medium text-[var(--color-text)] underline">Clear all filters</a>
              </div>
            {% endif %}
          </div>
        </div>
      </form>

      <!-- Pagination — all pages shown -->
      {% if paginate.pages > 1 %}
        <nav class="flex justify-center items-center flex-wrap gap-1 mt-12" aria-label="Pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="px-3 py-2 border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-background-alt)] no-underline text-[var(--color-text)] text-sm" aria-label="Previous page">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
            </a>
          {% endif %}

          {% for i in (1..paginate.pages) %}
            {% if i == paginate.current_page %}
              <span class="w-10 h-10 flex items-center justify-center bg-[var(--color-primary)] text-white rounded-lg text-sm" aria-current="page">{{ i }}</span>
            {% else %}
              {%- assign page_url = paginate.collection_url | append: '?page=' | append: i -%}
              {%- if current_tags -%}
                {%- assign page_url = paginate.collection_url | append: '/' | append: current_tags | join: '+' | append: '?page=' | append: i -%}
              {%- endif -%}
              <a href="{{ page_url }}" class="w-10 h-10 flex items-center justify-center border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-background-alt)] no-underline text-[var(--color-text)] text-sm">{{ i }}</a>
            {% endif %}
          {% endfor %}

          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="px-3 py-2 border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-background-alt)] no-underline text-[var(--color-text)] text-sm" aria-label="Next page">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          {% endif %}
        </nav>
      {% endif %}
    </collection-filters>
  </div>
</section>
{% endpaginate %}

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    }
  ]
}
{% endschema %}
